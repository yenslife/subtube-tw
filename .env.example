# ============================================================
# LLM provider
# ============================================================

# 預設使用 OpenAI；若要改走 OpenRouter，設定：
# LLM_PROVIDER=openrouter
LLM_PROVIDER=openai

# ============================================================
# OpenAI
# ============================================================

# OpenAI provider 必填：OpenAI API key
OPENAI_API_KEY=

# 字幕翻譯模型
OPENAI_MODEL=gpt-5.4-nano

# 建立全片上下文摘要 / 上傳 description 用的模型
# 不填的話程式會 fallback 到 OPENAI_MODEL
OPENAI_SUMMARY_MODEL=gpt-4.1-mini

# ============================================================
# OpenRouter
# ============================================================

# 若 LLM_PROVIDER=openrouter，必填：
OPENROUTER_API_KEY=

# OpenRouter 模型名稱要用 provider/model 格式，例如：
# OPENROUTER_MODEL=openai/gpt-4.1-mini
# OPENROUTER_MODEL=anthropic/claude-3.5-haiku
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# 省錢優先：大 context，適合大 chunk + overlap
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# 品質優先可改：google/gemini-2.5-flash
# 不填的話 fallback 到 OPENROUTER_MODEL
OPENROUTER_SUMMARY_MODEL=google/gemini-2.5-flash-lite

# 通常不用改
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 可選：OpenRouter app metadata
OPENROUTER_APP_TITLE=SubTube TW
# OPENROUTER_HTTP_REFERER=https://your-site.example

# ============================================================

# Translation performance / quality

# ============================================================

# 每個字幕 chunk 最大字元數

# 大 target chunk；搭配 Gemini / 其他大 context 模型使用。
CHUNK_MAX_CHARS=6000

# chunk 切分時的時間間隔閾值（秒）；字幕間隔超過此值時優先切分。
CHUNK_GAP_SECONDS=2.0

# 前後文 overlap 只供模型理解，不要求輸出，可降低跨 chunk 語境斷裂。
CHUNK_OVERLAP_SECONDS=120.0

# reference 字幕使用 timecode overlap 對齊，額外帶入 target+overlap 前後秒數。
REFERENCE_WINDOW_SECONDS=6.0

# 舊版編號對齊 fallback，通常不需要改。
REFERENCE_WINDOW_BEFORE=40
REFERENCE_WINDOW_AFTER=40

# 建立全片上下文時，每個字幕檔最多取多少字元

MAX_SPLIT_RETRY_DEPTH=2
SUMMARY_MAX_CHARS_PER_FILE=20000

# OpenAI-compatible API 失敗重試次數
MAX_RETRIES=2

# 單次 LLM API call timeout 秒數；失敗快點重跑，別讓整個流程裝死。
LLM_TIMEOUT_SECONDS=60

# 大 chunk 需要足夠輸出 token，避免模型在 chunk 後段被截斷漏 ID。
LLM_MAX_OUTPUT_TOKENS=16000

# 平行翻譯 chunk 數量
# 預設 5，保留平行 API 呼叫；若 provider 不穩再降到 1~3。

MAX_WORKERS=5

# 翻譯快取目錄

CACHE_DIR=.cache_translate

# ============================================================

# YouTube upload

# ============================================================

# 是否在翻譯與 mux 完成後自動上傳到 YouTube

# 0 = 不上傳

# 1 = 上傳

UPLOAD_YOUTUBE=0

# 你的私人播放清單 ID

# 例如：https://www.youtube.com/playlist?list=PLxxxxxxxx

# 就填 PLxxxxxxxx

YOUTUBE_PLAYLIST_ID=

# 上傳影片標題
# 預設會使用："(赫米翻譯) 原始影片標題"
# 若要手動覆寫才取消註解：
# YOUTUBE_TITLE="Translated YouTube Video"

# 上傳影片描述
# 預設會由 generate_upload_metadata.py 用 OpenAI 根據 metadata + 翻譯字幕自動產生。
# 若要手動覆寫才取消註解：
# YOUTUBE_DESCRIPTION="Private translated copy for personal viewing."

# private / unlisted / public

YOUTUBE_PRIVACY=private

# OAuth client secret / token 路徑

# 通常放專案根目錄即可

YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json

# ============================================================

# Optional: yt-dlp / workflow behavior

# ============================================================

# 每次輸出的工作目錄名稱；不設定時腳本會自動產生 youtube_translation_YYYYmmdd_HHMMSS

# WORKDIR=youtube_translation_test

# YouTube 若出現「Sign in to confirm you’re not a bot」，需要提供瀏覽器 cookies。
# 建議從已登入 YouTube 的本機瀏覽器匯出 Netscape cookies 格式，放在專案根目錄：
#   youtube.cookies.txt
# 這個檔案等同登入憑證，絕對不要 commit、不要傳給陌生服務。
YTDLP_COOKIES_FILE=youtube.cookies.txt

# 如果是在同一台有瀏覽器 profile 的電腦上執行，也可以改用：
# YTDLP_COOKIES_FROM_BROWSER=firefox
# YTDLP_COOKIES_FROM_BROWSER=chrome

# YouTube 有時會要求 JS challenge solving。腳本會自動偵測 node；必要時可手動指定：
# YTDLP_JS_RUNTIME=node:/path/to/node
# YTDLP_REMOTE_COMPONENTS=ejs:github

# 影片下載格式；預設偏好 H.264 + AAC。若特定 1080p format 被 YouTube 403，可暫時改 720p：
# YTDLP_VIDEO_FORMAT="136+140/18"

# 預設抓外語字幕作為語境：英文 primary + 韓文/日文 reference。
# 若真的要嘗試中文字幕端點，可自行加：zh-Hant zh-TW zh-Hans zh-CN
SUBTITLE_LANGS="en ko ja"

# 預設抓 primary + 2 個 reference 字幕，通常可取得 ko/en/ja 多語語境。
# 想更準可調高；想少打 YouTube 字幕端點可調低。
MIN_REFERENCE_SUBTITLES=2

# 單一字幕語言下載 timeout 秒數，避免 yt-dlp 卡住
YTDLP_SUBTITLE_TIMEOUT_SECONDS=120
